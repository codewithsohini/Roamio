{
  "name": "roamio",
  "version": "1.0.0",
  "private": true,
  "description": "Roamio — AI Travel Planner. Run npm install then npm run dev.",
  "scripts": {
    "install:frontend": "cd frontend && npm install",
    "install:backend": "cd backend && pip install -r requirements.txt",
    "postinstall": "npm run install:frontend",
    "dev": "concurrently --kill-others --names \"BACKEND,FRONTEND\" --prefix-colors \"cyan,magenta\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}